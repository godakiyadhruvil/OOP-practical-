import javafx.animation.AnimationTimer;
import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Slider;
import javafx.scene.layout.AnchorPane;
import javafx.scene.layout.HBox;
import javafx.scene.paint.Color;
import javafx.scene.shape.Circle;
import javafx.stage.Stage;

public class BouncingBallFX extends Application {

    private double dx = 2; // speed factor
    private boolean running = false;

    @Override
    public void start(Stage stage) {

        AnchorPane root = new AnchorPane();

        Circle ball = new Circle(20, Color.BLUE);
        ball.setCenterX(50);
        ball.setCenterY(100);

        Button startBtn = new Button("Start");
        Button stopBtn = new Button("Stop");

        Slider speedSlider = new Slider(1, 10, 2);
        speedSlider.setShowTickLabels(true);
        speedSlider.setShowTickMarks(true);

        HBox controls = new HBox(10, startBtn, stopBtn, speedSlider);
        controls.setLayoutX(20);
        controls.setLayoutY(200);

        root.getChildren().addAll(ball, controls);

        AnimationTimer timer = new AnimationTimer() {
            @Override
            public void handle(long now) {
                if (!running) return;

                double radius = ball.getRadius();
                double nextX = ball.getCenterX() + dx;

                double width = root.getWidth();

                if (nextX - radius <= 0 || nextX + radius >= width) {
                    dx = -dx;
                }

                ball.setCenterX(ball.getCenterX() + dx);
            }
        };

        startBtn.setOnAction(e -> running = true);
        stopBtn.setOnAction(e -> running = false);

        speedSlider.valueProperty().addListener((obs, oldVal, newVal) -> {
            double sign = dx >= 0 ? 1 : -1;
            dx = sign * newVal.doubleValue();
        });

        timer.start();

        Scene scene = new Scene(root, 400, 300);
        stage.setTitle("Bouncing Ball");
        stage.setScene(scene);
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
